<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.jomof.dap</id>
    <name>Dap</name>
    <vendor>jomof</vendor>

    <description><![CDATA[
        Bridges the Debug Adapter Protocol (DAP) to IntelliJ's debugger framework
        so any DAP-conformant debug adapter (lldb-dap, CodeLLDB, delve-dap, ...) can
        drive a native-code debug session in CLion and other IntelliJ-based IDEs.<br>
        <em>Scaffolded for C/C++ and Rust via lldb-dap/CodeLLDB and Go via delve-dap.</em>
        ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Scaffold: lets us actually run the plugin from CLion against real debug adapters.
             These registrations live in the scaffold package and will be removed when the
             production DAP layer is transplanted into a larger codebase. -->
        <programRunner implementation="com.github.jomof.dap.scaffold.run.ScaffoldDapDebugRunner"/>
        <configurationType implementation="com.github.jomof.dap.scaffold.run.ScaffoldDapConfigurationType"/>
        <xdebugger.breakpointType
            implementation="com.github.jomof.dap.scaffold.breakpoints.CppLineBreakpointType"/>
        <xdebugger.breakpointType
            implementation="com.github.jomof.dap.scaffold.breakpoints.RustLineBreakpointType"/>
        <xdebugger.breakpointType
            implementation="com.github.jomof.dap.scaffold.breakpoints.GoLineBreakpointType"/>
    </extensions>
</idea-plugin>
